{
  "name": "axi-factorio",
  "version": "0.1.0-rc.3",
  "description": "A deliberately dumb SQLite conveyor for tool-driven work.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "axi-factorio": "./dist/src/cli.js"
  },
  "files": [
    "dist",
    "AXI-CONFORMANCE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "axi": "node --disable-warning=ExperimentalWarning src/cli.ts",
    "build": "node --disable-warning=ExperimentalWarning scripts/BuildRelease.ts",
    "check": "node --disable-warning=ExperimentalWarning src/cli.ts --version",
    "test": "node --disable-warning=ExperimentalWarning --test tests/*.test.ts",
    "workbench": "node --disable-warning=ExperimentalWarning src/WorkbenchServer.ts"
  },
  "engines": {
    "node": ">=23.6"
  },
  "dependencies": {
    "@toon-format/toon": "2.3.1"
  }
}
